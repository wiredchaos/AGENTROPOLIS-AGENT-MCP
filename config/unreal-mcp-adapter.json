{
  "schemaVersion": "1.0.0",
  "adapterId": "unreal-engine",
  "displayName": "Unreal MCP",
  "status": "DISABLED_BY_DEFAULT",
  "pilotMode": "READ_ONLY",
  "endpoint": "http://127.0.0.1:8000/mcp",
  "networkBoundary": "LOOPBACK_ONLY",
  "authenticationAssumption": "NONE",
  "parallelMutationsAllowed": false,
  "receiptRequired": true,
  "allowedCapabilities": [
    "list_toolsets",
    "describe_toolset",
    "inspect_project",
    "inspect_map",
    "inspect_actor",
    "capture_editor_screenshot"
  ],
  "deniedCapabilities": [
    "create_actor",
    "modify_actor",
    "delete_actor",
    "modify_blueprint",
    "save_package",
    "render",
    "export",
    "publish"
  ],
  "activationRequirements": [
    "unreal_editor_running",
    "unreal_mcp_plugin_enabled",
    "alltoolsets_plugin_enabled",
    "loopback_endpoint_verified",
    "approved_test_project",
    "approved_test_map",
    "operator_present",
    "receipt_destination_configured"
  ],
  "killConditions": [
    "endpoint_not_loopback",
    "project_identity_mismatch",
    "map_identity_mismatch",
    "write_or_mutation_requested",
    "tool_schema_not_discovered_live",
    "receipt_generation_failed",
    "authority_revoked"
  ],
  "canonicalContract": "docs/UNREAL_MCP_EXECUTION_LANE.md"
}
